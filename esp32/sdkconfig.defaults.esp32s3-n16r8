# ESP32-S3-N16R8 (16 MB flash, 8 MB PSRAM)
# Append to sdkconfig.defaults or copy as sdkconfig.defaults

# Custom partition table — shared 16 MB layout (app0/app1 = 4 MB each, spiffs
# ~7.9 MB). Chip-independent flash map; same file for classic-16mb and P4-NANO.
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions/ota_16mb.csv"

# Flash size override (default is 2MB on ESP32-S3)
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y

# PSRAM
CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
