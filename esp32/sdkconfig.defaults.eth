# Ethernet — defaults for the Olimex ESP32-Gateway (LAN8720 RMII, MDIO addr 0,
# PHY reset on GPIO 5). The esp32-eth and esp32-eth-wifi build variants were
# tested on this board:
#   https://www.olimex.com/Products/IoT/ESP32/ESP32-GATEWAY/open-source-hardware
#
# Layered onto sdkconfig.defaults by scripts/build/build_esp32.py.
#
# Boards with the same PHY family (LAN8720) but different pin maps —
# WT32-ETH01 (reset on GPIO 16, RMII clock output) — need a different
# fragment or a local rebuild today; runtime PHY/pin selection is on the
# 2.0 roadmap (see docs/plan.md).

CONFIG_ETH_USE_ESP32_EMAC=y
CONFIG_ETH_PHY_INTERFACE_RMII=y
CONFIG_ETH_PHY_ADDR=0
CONFIG_ETH_PHY_RST_GPIO=5
CONFIG_ETH_DMA_BUFFER_SIZE=512
CONFIG_ETH_DMA_RX_BUFFER_NUM=10
CONFIG_ETH_DMA_TX_BUFFER_NUM=10
