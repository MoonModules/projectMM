# ESP32 classic with 16 MB flash (e.g. Serg boards, QuinLED Dig-Octa).
# Append to sdkconfig.defaults (later fragment wins): overrides the base 4 MB
# flash size + esp32dev.csv partition with a 16 MB layout. No PSRAM — this is a
# classic-ESP32 WiFi build; the win is bigger OTA slots + filesystem, not RAM.

# Custom partition table — shared 16 MB layout (app0/app1 = 4 MB each, spiffs
# ~7.9 MB). Chip-independent flash map; same file for S3-N16R8 and P4-NANO.
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions/ota_16mb.csv"

# Flash size override (base default is 4MB). Only the choice symbol — the
# FLASHSIZE string is derived from it, matching the esp32s3-n16r8/n8r8 fragments.
CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
