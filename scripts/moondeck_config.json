    },
    {
      "id": "scenario_pipeline",
      "tab": "pc",
      "group": "test",
      "label": "Scenarios",
      "help": "scenario_pipeline",
      "script": "scenario/run_scenario.py",
      "needs_module": true,
      "needs_scenario": true
    },
    {
      "id": "run_desktop",
      "tab": "pc",
      "group": "run",
      "label": "Run",
      "help": "run_desktop",
      "script": "run/run_desktop.py",
      "long_running": true,
      "process_name": "projectMM"
    },
    {
      "id": "show_crash_log",
      "tab": "pc",
      "group": "run",
      "label": "Crash Log",
