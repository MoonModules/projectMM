      "process_name": "screenshot_modules.py",
      "flags": [
        { "id": "gif",   "label": "GIF",   "arg": "--gif",    "default": true },
        { "id": "force", "label": "Force", "arg": "--force",  "default": false }
      ]
    },
    {
      "id": "update_module_docs",
      "tab": "pc",
      "group": "docs",
      "label": "Update Module Docs",
      "help": "update_module_docs",
      "script": "docs/update_module_docs.py"
    },
