{
  "name": "control-change",
  "description": "Measure performance impact of control changes on a running system",
  "steps": [
    {
      "name": "baseline",
      "op": "set_control",
      "id": "Noise",
      "key": "scale",
      "value": 4,
      "measure": true,
      "bounds": { "fps": { "min_pct": 80 } }
    },
    {
      "name": "disable-mirrorX",
      "op": "set_control",
      "id": "Mirror",
      "key": "mirrorX",
      "value": false,
      "measure": true
    },
    {
      "name": "disable-mirrorY",
      "op": "set_control",
      "id": "Mirror",
      "key": "mirrorY",
      "value": false,
      "measure": true
    },
    {
      "name": "re-enable-mirrors",
      "op": "set_control",
      "id": "Mirror",
      "key": "mirrorX",
      "value": true
    },
    {
      "name": "re-enable-mirrorY",
      "op": "set_control",
      "id": "Mirror",
      "key": "mirrorY",
      "value": true,
      "measure": true,
      "bounds": { "fps": { "min_pct": 50 } }
    }
  ]
}
