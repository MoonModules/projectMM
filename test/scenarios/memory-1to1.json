{
  "name": "memory-1to1",
  "description": "Verify 1:1 unshuffled mapping uses no LUT and no driver buffer",
  "steps": [
    {
      "name": "add-layout-group",
      "op": "add_module",
      "id": "LayoutGroup",
      "type": "LayoutGroup"
    },
    {
      "name": "add-grid",
      "op": "add_module",
      "id": "Grid",
      "type": "GridLayout",
      "parent_id": "LayoutGroup",
      "props": {"width": 16, "height": 16}
    },
    {
      "name": "add-layer",
      "op": "add_module",
      "id": "Layer",
      "type": "Layer",
      "props": {"layoutGroup": "LayoutGroup", "channelsPerLight": 3}
    },
    {
      "name": "add-rainbow",
      "op": "add_module",
      "id": "Rainbow",
      "type": "RainbowEffect",
      "parent_id": "Layer"
    },
    {
      "name": "add-driver-group",
      "op": "add_module",
      "id": "DriverGroup",
      "type": "DriverGroup",
      "props": {"layer": "Layer"}
    },
    {
      "name": "add-artnet",
      "op": "add_module",
      "id": "ArtNet",
      "type": "ArtNetSendDriver",
      "parent_id": "DriverGroup",
      "measure": true,
      "bounds": {
        "fps": {"min_pct": 80}
      }
    }
  ]
}
