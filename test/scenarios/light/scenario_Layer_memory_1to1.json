{
  "name": "scenario_Layer_memory_1to1",
  "module": "Layer",
  "mode": "construct",
  "also": [
    "MappingLUT",
    "BlendMap"
  ],
  "description": "Verify that an unshuffled 1:1 mapping (no modifier) uses no LUT and no driver buffer. Catches a regression where Layer would allocate a passthrough LUT for the identity case.",
  "steps": [
    {
      "name": "add-layout-group",
      "description": "Create the top-level Layouts container.",
      "op": "add_module",
      "id": "Layouts",
      "type": "Layouts"
    },
    {
      "name": "add-grid",
      "description": "Add a 16x16 GridLayout.",
      "op": "add_module",
      "id": "Grid",
      "type": "GridLayout",
      "parent_id": "Layouts",
      "props": {
        "width": 16,
        "height": 16
      }
    },
    {
      "name": "add-layer",
      "description": "Add a Layer wired to Layouts (RGB).",
      "op": "add_module",
      "id": "Layer",
      "type": "Layer",
      "props": {
        "layouts": "Layouts",
        "channelsPerLight": 3
      }
    },
    {
      "name": "add-rainbow",
      "description": "Add RainbowEffect as the Layer's effect.",
      "op": "add_module",
      "id": "Rainbow",
      "type": "RainbowEffect",
      "parent_id": "Layer"
    },
    {
      "name": "add-driver-group",
      "description": "Add a Drivers container wired to the Layer.",
      "op": "add_module",
      "id": "Drivers",
      "type": "Drivers",
      "props": {
        "layer": "Layer"
      }
    },
    {
      "name": "add-artnet",
      "description": "Add ArtNetSendDriver and run the bounded FPS measurement on the no-LUT path.",
      "op": "add_module",
      "id": "ArtNet",
      "type": "ArtNetSendDriver",
      "parent_id": "Drivers",
      "measure": true,
      "bounds": {
        "fps": {
          "min_pct": 80
        }
      },
      "contract": {
        "pc-macos": {
          "tick_us": 50,
          "free_heap": 0,
          "set_by": "2026-06-02",
          "reason": "initial contract"
        }
      },
      "observed": {
        "pc-macos": {
          "tick_us": [
            0,
            80
          ],
          "free_heap": [
            0,
            0
          ],
          "max_alloc_block": [
            0,
            0
          ],
          "at": [
            "2026-06-02",
            "2026-06-05"
          ]
        }
      }
    }
  ]
}
