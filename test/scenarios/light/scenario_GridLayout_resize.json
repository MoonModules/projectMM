{
  "name": "scenario_GridLayout_resize",
  "module": "GridLayout",
  "mode": "mutate",
  "also": [
    "MultiplyModifier",
    "Layer"
  ],
  "description": "Resize the grid while the pipeline is running and verify it reallocates cleanly under memory pressure. Lowers to 128x64 (release memory), increases to 128x128 (heaviest config: mirror + LUT). Each measured step captures tick/FPS/heap so the runner reports the degrade behaviour.",
  "fixture": [
    {
      "name": "fix-layouts",
      "op": "add_module",
      "id": "Layouts",
      "type": "Layouts"
    },
    {
      "name": "fix-layers",
      "op": "add_module",
      "id": "Layers",
      "type": "Layers",
      "props": {
        "layouts": "Layouts"
      }
    },
    {
      "name": "fix-drivers",
      "op": "add_module",
      "id": "Drivers",
      "type": "Drivers",
      "props": {
        "layers": "Layers"
      }
    }
  ],
  "steps": [
    {
      "name": "canvas-clear-layers",
      "description": "Self-canvas: clear+rebuild the pipeline this scenario assumes, so it runs from any device state (the perf scenarios' pattern). Pre-wired apparatus (Preview/Board) survives clear_children. On the in-process runner the fixture already built the tree; clearing then rebuilding is harmless there and makes the live run order-independent.",
      "op": "clear_children",
      "id": "Layers"
    },
    {
      "name": "canvas-clear-layouts",
      "op": "clear_children",
      "id": "Layouts"
    },
    {
      "name": "canvas-clear-drivers",
      "op": "clear_children",
      "id": "Drivers"
    },
    {
      "name": "canvas-grid",
      "op": "add_module",
      "id": "Grid",
      "type": "GridLayout",
      "parent_id": "Layouts",
      "props": {
        "width": 128,
        "height": 128
      }
    },
    {
      "name": "canvas-layer",
      "op": "add_module",
      "id": "Layer",
      "type": "Layer",
      "parent_id": "Layers",
      "props": {
        "channelsPerLight": 3
      }
    },
    {
      "name": "canvas-noise",
      "op": "add_module",
      "id": "Noise",
      "type": "NoiseEffect",
      "parent_id": "Layer"
    },
    {
      "name": "canvas-mirror",
      "op": "add_module",
      "id": "Multiply",
      "type": "MultiplyModifier",
      "parent_id": "Layer"
    },
    {
      "name": "canvas-artnet",
      "op": "add_module",
      "id": "ArtNet",
      "type": "NetworkSendDriver",
      "parent_id": "Drivers"
    },
