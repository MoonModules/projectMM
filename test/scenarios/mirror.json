{
  "name": "mirror",
  "description": "Pipeline with mirror modifier: noise effect + XY kaleidoscope",
  "steps": [
    {
      "name": "add-layout-group",
      "op": "add_module",
      "id": "LayoutGroup",
      "type": "LayoutGroup"
    },
    {
      "name": "add-grid",
      "op": "add_module",
      "id": "Grid",
      "type": "GridLayout",
      "parent_id": "LayoutGroup"
    },
    {
      "name": "add-layer",
      "op": "add_module",
      "id": "Layer",
      "type": "Layer",
      "props": {
        "layoutGroup": "LayoutGroup",
        "channelsPerLight": 3
      }
    },
    {
      "name": "add-noise",
      "op": "add_module",
      "id": "Noise",
      "type": "NoiseEffect",
      "parent_id": "Layer"
    },
    {
      "name": "add-mirror",
      "op": "add_module",
      "id": "Mirror",
      "type": "MirrorModifier",
      "parent_id": "Layer"
    },
    {
      "name": "add-driver-group",
      "op": "add_module",
      "id": "DriverGroup",
      "type": "DriverGroup",
      "props": {
        "layer": "Layer"
      }
    },
    {
      "name": "add-artnet",
      "op": "add_module",
      "id": "ArtNet",
      "type": "ArtNetSendDriver",
      "parent_id": "DriverGroup",
      "measure": true,
      "bounds": {
        "fps": { "min_pct": 80 }
      }
    }
  ]
}
