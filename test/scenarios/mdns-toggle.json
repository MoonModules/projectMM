{
  "name": "mdns-toggle",
  "description": "Measure FPS impact of mDNS on/off",
  "steps": [
    {
      "name": "baseline-mdns-on",
      "op": "set_control",
      "id": "Network",
      "key": "mDNS",
      "value": true,
      "measure": true
    },
    {
      "name": "mdns-off",
      "op": "set_control",
      "id": "Network",
      "key": "mDNS",
      "value": false,
      "measure": true
    },
    {
      "name": "mdns-on-again",
      "op": "set_control",
      "id": "Network",
      "key": "mDNS",
      "value": true,
      "measure": true,
      "bounds": { "fps": { "min_pct": 80 } }
    }
  ]
}
