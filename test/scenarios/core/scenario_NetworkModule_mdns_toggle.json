{
  "name": "scenario_NetworkModule_mdns_toggle",
  "module": "NetworkModule",
  "mode": "mutate",
  "live_only": true,
  "description": "Toggle the mDNS responder on and off and measure render-FPS impact. Validates that mDNS announcement traffic doesn't degrade the render loop more than 20% on the busiest tick.",
  "reset": [
    {
      "name": "reset-grid-width",
      "op": "set_control",
      "id": "Grid",
      "key": "width",
      "value": 128
    },
    {
      "name": "reset-grid-height",
      "op": "set_control",
      "id": "Grid",
      "key": "height",
      "value": 128
    },
    {
      "name": "reset-mirrorX",
      "op": "set_control",
      "id": "Mirror",
      "key": "mirrorX",
      "value": true
    },
    {
      "name": "reset-mirrorY",
      "op": "set_control",
      "id": "Mirror",
      "key": "mirrorY",
      "value": true
    },
    {
      "name": "reset-mdns",
      "op": "set_control",
      "id": "Network",
      "key": "mDNS",
      "value": true
    }
  ],
  "steps": [
