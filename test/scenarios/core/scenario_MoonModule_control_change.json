{
  "name": "scenario_MoonModule_control_change",
  "module": "MoonModule",
  "mode": "mutate",
  "also": [
    "MultiplyModifier",
    "NoiseEffect"
  ],
  "description": "Measure the cost of control changes on a running pipeline. Toggles MultiplyModifier's mirrorX/Y at different points and verifies each change is applied without freezing the render loop. Companion to the MoonModule control-change gate unit tests (unit_MoonModule_control_change_gate.cpp) — this is the live equivalent.",
  "fixture": [
    {
      "name": "fix-layouts",
      "op": "add_module",
      "id": "Layouts",
      "type": "Layouts"
    },
    {
      "name": "fix-layers",
      "op": "add_module",
      "id": "Layers",
      "type": "Layers",
      "props": {
        "layouts": "Layouts"
      }
    },
    {
      "name": "fix-drivers",
      "op": "add_module",
      "id": "Drivers",
      "type": "Drivers",
      "props": {
        "layers": "Layers"
      }
    }
  ],
  "steps": [
    {
      "name": "canvas-clear-layers",
      "description": "Self-canvas: clear+rebuild the pipeline this scenario assumes, so it runs from any device state (order-independent in a chained live run). Pre-wired apparatus survives clear_children; replaces the old fixture+reset model.",
      "op": "clear_children",
      "id": "Layers"
    },
    {
      "name": "canvas-clear-layouts",
      "op": "clear_children",
      "id": "Layouts"
    },
    {
      "name": "canvas-clear-drivers",
      "op": "clear_children",
      "id": "Drivers"
    },
    {
      "name": "canvas-grid",
      "op": "add_module",
      "id": "Grid",
      "type": "GridLayout",
      "parent_id": "Layouts",
      "props": {
        "width": 128,
        "height": 128
      }
    },
    {
      "name": "canvas-layer",
      "op": "add_module",
      "id": "Layer",
      "type": "Layer",
      "parent_id": "Layers",
      "props": {
        "channelsPerLight": 3
      }
    },
    {
      "name": "canvas-noise",
      "op": "add_module",
      "id": "Noise",
      "type": "NoiseEffect",
      "parent_id": "Layer"
    },
    {
      "name": "canvas-mirror",
      "op": "add_module",
      "id": "Multiply",
      "type": "MultiplyModifier",
      "parent_id": "Layer"
    },
    {
      "name": "canvas-artnet",
      "op": "add_module",
      "id": "ArtNet",
      "type": "NetworkSendDriver",
      "parent_id": "Drivers"
