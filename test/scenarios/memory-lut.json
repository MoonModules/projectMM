{
  "name": "memory-lut",
  "description": "Verify modifier with LUT allocates mapping table and driver buffer",
  "steps": [
    {
      "name": "add-layout-group",
      "op": "add_module",
      "id": "Layouts",
      "type": "Layouts"
    },
    {
      "name": "add-grid",
      "op": "add_module",
      "id": "Grid",
      "type": "GridLayout",
      "parent_id": "Layouts",
      "props": {"width": 16, "height": 16}
    },
    {
      "name": "add-layer",
      "op": "add_module",
      "id": "Layer",
      "type": "Layer",
      "props": {"layouts": "Layouts", "channelsPerLight": 3}
    },
    {
      "name": "add-noise",
      "op": "add_module",
      "id": "Noise",
      "type": "NoiseEffect",
      "parent_id": "Layer"
    },
    {
      "name": "add-mirror",
      "op": "add_module",
      "id": "Mirror",
      "type": "MirrorModifier",
      "parent_id": "Layer"
    },
    {
      "name": "add-driver-group",
      "op": "add_module",
      "id": "Drivers",
      "type": "Drivers",
      "props": {"layer": "Layer"}
    },
    {
      "name": "add-artnet",
      "op": "add_module",
      "id": "ArtNet",
      "type": "ArtNetSendDriver",
      "parent_id": "Drivers",
      "measure": true,
      "bounds": {
        "fps": {"min_pct": 80}
      }
    }
  ]
}
