{
  "name": "grid-resize",
  "description": "Resize the grid via REST and verify the pipeline reallocates cleanly under memory pressure. Lowers to 128x64 (release memory), increases to 128x128 (heaviest config: mirror + LUT). Each measure captures tick/FPS/heap so the live runner reports the degrade behavior.",
  "steps": [
    {
      "name": "reset-mirrorX",
      "op": "set_control",
      "id": "Mirror",
      "key": "mirrorX",
      "value": true
    },
    {
      "name": "reset-mirrorY",
      "op": "set_control",
      "id": "Mirror",
      "key": "mirrorY",
      "value": true
    },
    {
      "name": "size-128x128",
      "op": "set_control",
      "id": "Grid",
      "key": "height",
      "value": 128,
      "measure": true
    },
    {
      "name": "shrink-to-128x64",
      "op": "set_control",
      "id": "Grid",
      "key": "height",
      "value": 64,
      "measure": true,
      "bounds": { "fps": { "min_pct": 80 } }
    },
    {
      "name": "grow-to-128x128",
      "op": "set_control",
      "id": "Grid",
      "key": "height",
      "value": 128,
      "measure": true
    }
  ]
}
