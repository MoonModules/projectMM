{
  "name": "base-pipeline",
  "description": "Core pipeline: grid layout, rainbow effect, ArtNet output",
  "steps": [
    {
      "name": "add-layout-group",
      "op": "add_module",
      "id": "Layouts",
      "type": "Layouts"
    },
    {
      "name": "add-grid",
      "op": "add_module",
      "id": "Grid",
      "type": "GridLayout",
      "parent_id": "Layouts"
    },
    {
      "name": "add-layer",
      "op": "add_module",
      "id": "Layer",
      "type": "Layer",
      "props": {
        "layouts": "Layouts",
        "channelsPerLight": 3
      }
    },
    {
      "name": "add-rainbow",
      "op": "add_module",
      "id": "Rainbow",
      "type": "RainbowEffect",
      "parent_id": "Layer"
    },
    {
      "name": "add-driver-group",
      "op": "add_module",
      "id": "Drivers",
      "type": "Drivers",
      "props": {
        "layer": "Layer"
      }
    },
    {
      "name": "add-artnet",
      "op": "add_module",
      "id": "ArtNet",
      "type": "ArtNetSendDriver",
      "parent_id": "Drivers",
      "measure": true,
      "bounds": {
        "fps": { "min_pct": 80, "min_fps_led_product": 294912 }
      }
    }
  ]
}
